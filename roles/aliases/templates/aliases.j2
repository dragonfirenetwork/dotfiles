# ~/.aliases — managed by the dotfiles 'aliases' role.
# NOTE: work / corporate-specific aliases (internal hostnames, work scripts,
# ansible-vault helpers, etc.) are intentionally NOT kept here, since this
# repo is public. Keep those in a separate, untracked ~/.aliases.local and
# add `source ~/.aliases.local` to your shell if you want them loaded.

# OS convenience aliases
alias update='brew update && brew upgrade && brew cleanup'
alias la='ls -la'
alias ll='tree -L 3'

# Generate a random string
alias ct='openssl rand -base64 32 | pbcopy | echo "Token copied to clipboard"'

# Zoxide
export _ZO_DOCTOR=0
alias cd="z"
eval "$(zoxide init zsh)"

# Asciiquarium
alias brb=asciiquarium
alias aq=asciiquarium

# Bat
alias cat=bat

# Fastfetch (neofetch is discontinued; alias the old muscle-memory name)
alias neofetch=fastfetch
alias ff=fastfetch

# SSH
sshfix() {
    ssh-keygen -R "$1"
}
alias ssha='eval $(ssh-agent) && ssh-add'

# Tmux dev environment session
alias td='~/.config/tmux/tmux-dev.sh'

# Quickly open directories
alias dotfiles='cd ~/.dotfiles'
alias personal='cd ~/personal'
alias work='cd ~/work'

# YUMI second brain (cognitive-repo) — runs bin/brain from anywhere (it self-locates its repo)
# Path is a vaulted var (cognitive_repo_path) so it isn't exposed in this public repo.
alias brain='{{ cognitive_repo_path }}/bin/brain'          # brain serve | find | index | lint
alias yumi='{{ cognitive_repo_path }}/bin/brain serve'     # launch the web UI at http://localhost:7777/webui/

# Git aliases
alias ga='git add .'
alias gc='git commit -m'
alias gp='git push'
alias gs='git status'
alias gd='git diff'
alias gu='git pull'

export PATH="$HOME/.local/bin:$PATH"

# Load machine-local / work-specific aliases if present (untracked)
[ -f "$HOME/.aliases.local" ] && source "$HOME/.aliases.local"
